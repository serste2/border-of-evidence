# Local frontend development
# Use the local backend SSE endpoint when running `npm run dev` in frontend and backend.
VITE_LIVE_EVENTS_URL=http://localhost:8787/api/events/live

# Production example
# Replace with the deployed backend URL when the Express backend is hosted.
# VITE_LIVE_EVENTS_URL=https://YOUR-BACKEND-DOMAIN/api/events/live
