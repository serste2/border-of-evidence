PORT=8787
GEMINI_API_KEY=replace_with_real_key
GEMINI_MODEL=gemini-1.5-flash
ALLOWED_ORIGIN=http://localhost:5173

# Live pulse simulation for frontend visual testing.
# Set false when real Seraphina ingestion is active.
SERAPHINA_SIMULATION_ENABLED=true

# RSS/news ingestion. Disabled by default for controlled local testing.
SERAPHINA_NEWS_POLLING_ENABLED=false
SERAPHINA_NEWS_POLL_INTERVAL_MS=300000
SERAPHINA_MAX_ARTICLES_PER_POLL=12
SERAPHINA_MIN_EVIDENCE_SCORE=0.6
SERAPHINA_NEWS_FEEDS=https://www.eea.europa.eu/en/newsroom/news.xml,https://www.fao.org/news/rss-feed/en/,https://www.euractiv.com/sections/agriculture-food/feed/,https://www.euractiv.com/sections/energy-environment/feed/
